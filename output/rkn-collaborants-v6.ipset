# IPSet blacklist configuration
# Last updated: 2026-06-08 15:52:54 UTC
#
# Usage:
#   1. Load the ipset:
#      ipset restore < rkn-collaborants-v6.ipset
#
#   2. Use with ip6tables:
#      ip6tables -I INPUT -m set --match-set rkn-collaborants-v6 src -m conntrack --ctstate NEW -j DROP
#      ip6tables -I FORWARD -m set --match-set rkn-collaborants-v6 src -m conntrack --ctstate NEW -j DROP
#
#   3. To flush/delete the set:
#      ipset flush rkn-collaborants-v6
#      ipset destroy rkn-collaborants-v6
#

create rkn-collaborants-v6 hash:net family inet6 hashsize 1024 maxelem 62
