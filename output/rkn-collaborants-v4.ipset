# IPSet blacklist configuration
# Last updated: 2026-06-08 15:52:54 UTC
#
# Usage:
#   1. Load the ipset:
#      ipset restore < rkn-collaborants-v4.ipset
#
#   2. Use with iptables:
#      iptables -I INPUT -m set --match-set rkn-collaborants-v4 src -m conntrack --ctstate NEW -j DROP
#      iptables -I FORWARD -m set --match-set rkn-collaborants-v4 src -m conntrack --ctstate NEW -j DROP
#
#   3. To flush/delete the set:
#      ipset flush rkn-collaborants-v4
#      ipset destroy rkn-collaborants-v4
#

